{
  "name": "@expressthat-auth/quality",
  "version": "0.0.0",
  "private": true,
  "description": "Coverage, file-size, boundary, and repository policy checks.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "check:artifacts": "tsx src/check-artifacts.ts",
    "check:boundaries": "tsx src/check-boundaries.ts",
    "check:licenses": "tsx src/check-licenses.ts",
    "check:lines": "tsx src/check-lines.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@expressthat-auth/test-config": "workspace:*",
    "@expressthat-auth/typescript-config": "workspace:*",
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "oxc-parser": "0.141.0",
    "tsx": "4.23.1",
    "zod": "4.4.3",
    "vitest": "4.1.10"
  }
}
