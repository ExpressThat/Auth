{
  "name": "@expressthat-auth/root",
  "version": "0.0.0",
  "private": true,
  "description": "A portable, multi-tenant authentication and identity platform.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.16.0",
  "engines": {
    "node": ">=24.18.0 <27",
    "pnpm": "11.16.0"
  },
  "scripts": {
    "build": "turbo run build",
    "check": "biome check . && pnpm check:lines && pnpm check:boundaries",
    "check:boundaries": "pnpm --filter @expressthat-auth/quality check:boundaries",
    "check:fix": "biome check --write .",
    "check:lines": "pnpm --filter @expressthat-auth/quality check:lines",
    "check:contracts": "turbo run check:contracts",
    "check:deployment": "turbo run check:deployment",
    "db:check": "turbo run db:check",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:reset": "turbo run db:reset",
    "dev": "turbo run dev",
    "dev:dependencies": "turbo run dev:dependencies",
    "deploy": "turbo run deploy",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "generate": "turbo run generate",
    "generate:contracts": "turbo run generate:contracts",
    "generate:sdk": "turbo run generate:sdk",
    "lint": "biome lint . && turbo run lint",
    "lint:fix": "biome lint --write .",
    "package:deployment": "turbo run package:deployment",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "turbo run test:e2e",
    "test:deployment": "turbo run test:deployment",
    "test:types": "turbo run test:types",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@expressthat-auth/typescript-config": "workspace:*",
    "tsx": "4.23.1",
    "turbo": "2.10.6",
    "typescript": "7.0.2"
  }
}
