{
  "name": "@expressthat-auth/test-config",
  "version": "0.0.0",
  "private": true,
  "description": "Shared test defaults, fixtures, and helpers.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./component": "./src/component.ts",
    "./playwright": "./src/playwright.ts",
    "./setup-dom": "./src/setup-dom.ts",
    "./vitest": "./src/vitest.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:types": "tsc --noEmit --project tsconfig.type-tests.json",
    "typecheck": "tsc --noEmit && tsc --noEmit --project tsconfig.e2e.json"
  },
  "devDependencies": {
    "@expressthat-auth/typescript-config": "workspace:*",
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "jsdom": "29.1.1",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "tsx": "4.23.1",
    "vitest": "4.1.10",
    "zod": "4.4.3"
  }
}
