{
  "name": "@expressthat-auth/test-config",
  "version": "0.0.0",
  "private": true,
  "description": "Shared test defaults, fixtures, and helpers.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./vitest": "./src/vitest.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:types": "tsc --noEmit --project tsconfig.type-tests.json",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@expressthat-auth/typescript-config": "workspace:*",
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "vitest": "4.1.10",
    "zod": "4.4.3"
  }
}
