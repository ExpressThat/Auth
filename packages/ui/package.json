{
  "name": "@expressthat-auth/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "output",
    "src"
  ],
  "exports": {
    "./react/*": {
      "import": "./output/react/src/*.tsx",
      "types": "./output/react/src/*.tsx"
    },
    "./vue/*": {
      "import": "./output/vue/src/*.vue"
    },
    "./svelte/*": {
      "import": "./output/svelte/src/*.svelte"
    },
    "./angular/*": {
      "import": "./output/angular/src/*.ts",
      "types": "./output/angular/src/*.ts"
    },
    "./solid/*": {
      "import": "./output/solid/src/*.tsx",
      "types": "./output/solid/src/*.tsx"
    },
    "./preact/*": {
      "import": "./output/preact/src/*.tsx",
      "types": "./output/preact/src/*.tsx"
    },
    "./qwik/*": {
      "import": "./output/qwik/src/*.tsx",
      "types": "./output/qwik/src/*.tsx"
    }
  },
  "scripts": {
    "build": "mitosis build && tsx scripts/build.ts",
    "dev": "mitosis build --watch",
    "check-types": "tsc --noEmit"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    },
    "@angular/common": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    },
    "preact": {
      "optional": true
    },
    "@builder.io/qwik": {
      "optional": true
    }
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17",
    "vue": "^3",
    "svelte": "^4 || ^5",
    "@angular/core": ">=17",
    "@angular/common": ">=17",
    "solid-js": "^1",
    "preact": "^10",
    "@builder.io/qwik": "^1"
  },
  "devDependencies": {
    "@builder.io/mitosis": "^0.13.0",
    "@builder.io/mitosis-cli": "^0.13.0",
    "@builder.io/qwik": "^1",
    "@expressthat-auth/typescript-config": "workspace:*",
    "@preact/preset-vite": "^2.10.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "esbuild": "^0.28.0",
    "preact": "^10",
    "solid-js": "^1",
    "svelte": "^5",
    "tslib": "^2.8.0",
    "@types/react": "^19.0.0",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-solid": "^2.11.8",
    "vue": "^3"
  }
}
