{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@expressthat-auth/typescript-config/base",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "@builder.io/mitosis",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "outDir": "dist",
    "rootDir": "src"
