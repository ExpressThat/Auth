{
  "name": "@expressthat-auth/api-client",
  "version": "0.0.1",
  "private": true,
  "description": "Generated TypeScript client for the ExpressThat Auth API",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "pnpm gen:types:release",
    "dev": "wait-on -t 300000 http-get://localhost:3001/api/swagger/v1/swagger.json && nodemon --watch ../api/bin/Debug/net10.0/swagger.json --ext json --exec \"pnpm gen:types:dev\"",
    "gen:types:release": "openapi-typescript ../api/bin/Release/net10.0/swagger.json -o src/schema.gen.ts",
    "gen:types:dev": "openapi-typescript ../api/bin/Debug/net10.0/swagger.json -o src/schema.gen.ts",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@expressthat-auth/api": "workspace:*",
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "@expressthat-auth/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "nodemon": "^3.1.10",
    "openapi-typescript": "^7.13.0",
    "typescript": "5.9.2",
    "wait-on": "^9.0.5"
  }
}
