{
  "name": "@expressthat-auth/api-client",
  "version": "0.0.1",
  "private": true,
  "description": "Generated TypeScript client for the ExpressThat Auth API",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "pnpm gen:client:release && tsx scripts/build.ts",
    "dev": "wait-on -t 300000 http-get://localhost:3001/api/swagger/v1/swagger.json && nodemon --watch ../../apps/api/bin/Debug/net10.0/swagger.json --ext json --exec \"pnpm gen:client:dev\"",
    "gen:client:release": "tsx scripts/gen-client.ts",
    "gen:client:dev": "tsx scripts/gen-client.ts ../../apps/api/bin/Debug/net10.0/swagger.json"
  },
  "devDependencies": {
    "api": "workspace:*",
    "@expressthat-auth/typescript-config": "workspace:*",
    "@types/node": "^24.12.2",
    "esbuild": "^0.28.0",
    "nodemon": "^3.1.10",
    "swagger-typescript-api": "^13.6.10",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  }
}
