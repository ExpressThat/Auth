{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [],
  "globalPassThroughEnv": ["AUTH_SECRET", "AUTH_GITHUB_ID", "AUTH_GITHUB_SECRET"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "output/**",
        "publish/**",
        "bin/Release/**",
        "obj/**/ref/**"
      ]
    },
    "check-types": {
      "dependsOn": ["build"],
      "cache": false
    },
    "//#format-and-lint": {},
    "//#format-and-lint:fix": {
      "cache": false
    },
    "dev": {
      "dependsOn": ["^build-proxy-components"],
      "cache": false,
      "persistent": true
    },
    "test:components": {
      "dependsOn": [],
      "cache": false
    },
    "test:e2e:web": {
      "dependsOn": [],
      "cache": false
    },
    "test:e2e:react": {
      "dependsOn": [],
      "cache": false
    },
    "test:e2e:vue": {
      "dependsOn": [],
      "cache": false
    },
    "test:e2e:remix": {
      "dependsOn": [],
      "cache": false
    },
    "test:e2e:remix-no-ssr": {
      "dependsOn": [],
      "cache": false
    },
    "test:e2e:react-router": {
      "dependsOn": [],
      "cache": false
    },
    "test:e2e:react-router-no-ssr": {
      "dependsOn": [],
      "cache": false
    },
    "test:e2e:angular": {
      "dependsOn": [],
      "cache": false
    },
    "test:e2e:angular-module": {
      "dependsOn": [],
      "cache": false
    },
    "test:e2e:nextjs": {
      "dependsOn": [],
      "cache": false
    },
    "test:e2e:nextjs-no-ssr": {
      "dependsOn": [],
      "cache": false
    },
    "test:e2e:nuxt": {
      "dependsOn": [],
      "cache": false
    },
    "test:e2e:nuxt-no-ssr": {
      "dependsOn": [],
      "cache": false
    },
    "build-proxy-components": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
